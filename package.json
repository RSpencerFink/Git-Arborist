{
  "name": "gw",
  "version": "0.1.0",
  "description": "Git Worktrees, Finally Simple",
  "type": "module",
  "bin": {
    "gw": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile gw",
    "test": "bun test",
    "lint": "bunx biome check src/",
    "format": "bunx biome format --write src/"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.2.4",
    "typescript": "^5.7.3"
  },
  "license": "MIT"
}
