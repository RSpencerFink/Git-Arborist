{
  "name": "arborist-worktrees",
  "displayName": "Git Arborist",
  "description": "Manage git worktrees with arb (git-arborist) directly from VS Code",
  "version": "0.1.0",
  "publisher": "rspencerfink",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rspencerfink/git-arborist"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "worktree",
    "worktrees",
    "arb",
    "git-arborist"
  ],
  "activationEvents": [
    "workspaceContains:.arborist.toml",
    "workspaceContains:.git"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "arborist.addWorktree",
        "title": "Git Arborist: Add Worktree",
        "icon": "$(add)"
      },
      {
        "command": "arborist.removeWorktree",
        "title": "Git Arborist: Remove Worktree",
        "icon": "$(trash)"
      },
      {
        "command": "arborist.switchWorktree",
        "title": "Git Arborist: Switch Worktree",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "arborist.switchToMain",
        "title": "Git Arborist: Switch to Main Worktree"
      },
      {
        "command": "arborist.pruneWorktrees",
        "title": "Git Arborist: Prune Merged Worktrees",
        "icon": "$(git-pull-request-closed)"
      },
      {
        "command": "arborist.cleanWorktree",
        "title": "Git Arborist: Clean Worktree"
      },
      {
        "command": "arborist.garbageCollect",
        "title": "Git Arborist: Garbage Collect"
      },
      {
        "command": "arborist.cloneRepo",
        "title": "Git Arborist: Clone Repository"
      },
      {
        "command": "arborist.initConfig",
        "title": "Git Arborist: Initialize Config"
      },
      {
        "command": "arborist.runSetup",
        "title": "Git Arborist: Run Setup Hooks"
      },
      {
        "command": "arborist.runInWorktree",
        "title": "Git Arborist: Run Command in Worktree"
      },
      {
        "command": "arborist.openDashboard",
        "title": "Git Arborist: Open Dashboard",
        "icon": "$(dashboard)"
      },
      {
        "command": "arborist.editConfig",
        "title": "Git Arborist: Edit Config"
      },
      {
        "command": "arborist.refreshWorktrees",
        "title": "Git Arborist: Refresh Worktrees",
        "icon": "$(refresh)"
      },
      {
        "command": "arborist.openWorktreeInNewWindow",
        "title": "Open in New Window",
        "icon": "$(window)"
      },
      {
        "command": "arborist.setupWorktree",
        "title": "Run Setup",
        "icon": "$(tools)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "arborist-worktrees",
          "title": "Git Arborist",
          "icon": "media/icons/trees.svg"
        }
      ]
    },
    "views": {
      "arborist-worktrees": [
        {
          "id": "arborist.worktreeView",
          "name": "Worktrees"
        },
        {
          "id": "arborist.pluginView",
          "name": "Plugins"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "arborist.addWorktree",
          "when": "view == arborist.worktreeView",
          "group": "navigation@1"
        },
        {
          "command": "arborist.refreshWorktrees",
          "when": "view == arborist.worktreeView",
          "group": "navigation@2"
        },
        {
          "command": "arborist.openDashboard",
          "when": "view == arborist.worktreeView",
          "group": "navigation@3"
        },
        {
          "command": "arborist.pruneWorktrees",
          "when": "view == arborist.worktreeView",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "arborist.switchWorktree",
          "when": "view == arborist.worktreeView && viewItem == worktree",
          "group": "inline@1"
        },
        {
          "command": "arborist.openWorktreeInNewWindow",
          "when": "view == arborist.worktreeView && viewItem == worktree",
          "group": "inline@2"
        },
        {
          "command": "arborist.removeWorktree",
          "when": "view == arborist.worktreeView && viewItem == worktree",
          "group": "inline@3"
        },
        {
          "command": "arborist.removeWorktree",
          "when": "view == arborist.worktreeView && viewItem == worktree",
          "group": "context@1"
        },
        {
          "command": "arborist.setupWorktree",
          "when": "view == arborist.worktreeView && viewItem == worktree",
          "group": "context@2"
        },
        {
          "command": "arborist.cleanWorktree",
          "when": "view == arborist.worktreeView && viewItem == worktree",
          "group": "context@3"
        }
      ]
    },
    "configuration": {
      "title": "Git Arborist",
      "properties": {
        "arborist.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Path to arb binary (auto-detect if empty)"
        },
        "arborist.switchBehavior": {
          "type": "string",
          "enum": [
            "newWindow",
            "replaceWindow"
          ],
          "default": "newWindow",
          "description": "Open worktree in new window or replace current"
        },
        "arborist.autoRefreshInterval": {
          "type": "number",
          "default": 10000,
          "minimum": 1000,
          "description": "Tree view auto-refresh interval in milliseconds"
        },
        "arborist.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show current worktree branch in status bar"
        },
        "arborist.dashboardRefreshInterval": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "description": "Dashboard auto-refresh interval in milliseconds"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "vsce package",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.24.0",
    "vitest": "^2.0.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
